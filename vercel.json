{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(index|works|atlas|writing).html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/works", "destination": "/works.html" },
    { "source": "/atlas", "destination": "/atlas.html" },
    { "source": "/writing", "destination": "/writing.html" }
  ]
}
